{
	"name": "n8n-nodes-gh-project-promoter",
	"version": "0.2.1",
	"description": "n8n community node for ghpp (GitHub Project Promoter)",
	"license": "MIT",
	"homepage": "https://github.com/douhashi/n8n-nodes-gh-project-promoter",
	"keywords": [
		"n8n-community-node-package"
	],
	"author": {
		"name": "douhashi"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/douhashi/n8n-nodes-gh-project-promoter.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"format": "prettier --check .",
		"format:fix": "prettier --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"postinstall": "node scripts/download-binary.js",
		"prepublishOnly": "n8n-node prerelease",
		"release": "bash scripts/release.sh"
	},
	"files": [
		"dist",
		"scripts",
		"bin"
	],
	"ghpp": {
		"version": "0.4.1"
	},
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": false,
		"credentials": [
			"dist/credentials/GhppApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Ghpp/Ghpp.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "^0.23.0",
		"eslint": "^9.0.0",
		"prettier": "^3.0.0",
		"typescript": "^5.0.0",
		"vitest": "^3.0.0",
		"@vitest/coverage-v8": "^3.0.0"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
